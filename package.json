{
  "name": "zotero-agent",
  "version": "0.1.0",
  "description": "Zotero Agent plugin for explain, translate, and ask workflows in Zotero 7/8.",
  "config": {
    "addonName": "Zotero Agent",
    "addonID": "zotero-agent@runzewang.dev",
    "addonRef": "zoteroagent",
    "prefsPrefix": "extensions.zotero.ZoteroAgent",
    "addonInstance": "ZoteroAgent"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "tsc --noEmit && zotero-plugin build",
    "release": "zotero-plugin release",
    "lint": "prettier --write . && eslint . --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "update-deps": "npm update --save"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runzewang/zotero-agent.git"
  },
  "author": "runzewang",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/runzewang/zotero-agent/issues"
  },
  "homepage": "https://github.com/runzewang/zotero-agent#readme",
  "dependencies": {
    "katex": "^0.16.44",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.5.2",
    "eslint": "^10.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "zotero-plugin-scaffold": "^0.8.5",
    "zotero-types": "^4.1.2"
  }
}
